# ── Stage 1: 编译 React 前端 ──────────────────────────────────────────────────
FROM node:20-alpine AS frontend
WORKDIR /web
COPY web/package*.json ./
RUN npm config set registry https://registry.npmmirror.com && npm ci --silent
COPY web/ ./
RUN npm run build

# ── Stage 2: 构建 Python 虚拟环境 ────────────────────────────────────────────
FROM python:3.12-slim AS builder
ENV PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/ \
 && pip config set global.trusted-host mirrors.aliyun.com
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
WORKDIR /build
COPY pyproject.toml ./
COPY tradingagents/ ./tradingagents/
COPY server/ ./server/
COPY cli/ ./cli/
RUN pip install -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com .

# ── Stage 3: 最终运行时镜像 ──────────────────────────────────────────────────
FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN useradd --create-home appuser \
 && install -d -m 0755 -o appuser -g appuser /home/appuser/.tradingagents

USER appuser
WORKDIR /home/appuser/app

COPY --chown=appuser:appuser pyproject.toml ./
COPY --chown=appuser:appuser server/ ./server/
COPY --chown=appuser:appuser tradingagents/ ./tradingagents/
COPY --chown=appuser:appuser cli/ ./cli/
COPY --chown=appuser:appuser manage_users.py ./

COPY --from=frontend --chown=appuser:appuser /web/dist ./web/dist

CMD ["uvicorn", "server.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
